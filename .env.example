PORT=3030
FRONTEND_URL=http://localhost:3000,http://127.0.0.1:3000,https://so7bafit.com
JWT_SECRET=
JWT_EXPIRE=1d
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=
# Keep below your Postgres/Supabase session pool limit (often 15).
DATABASE_POOL_SIZE=4
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# WhatsApp
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
WHATSAPP_SESSION_ENCRYPTION_KEY=
WHATSAPP_PROVIDER=wppconnect
WHATSAPP_MEDIA_ROOT=uploads/whatsapp-media
# Optional when Chrome/Chromium is not discoverable automatically.
# Required if Puppeteer Chromium was skipped during npm install.
CHROME_EXECUTABLE_PATH=

# WhatsApp AI reply suggestions (free ChatGPT web provider; no API key)
AI_REPLY_CHATGPT_URL=https://chatgpt.com/
AI_REPLY_HEADLESS=true
# Optional; falls back to CHROME_EXECUTABLE_PATH.
AI_REPLY_EXECUTABLE_PATH=
AI_REPLY_NAVIGATION_TIMEOUT_MS=60000
AI_REPLY_RESPONSE_TIMEOUT_MS=120000
AI_REPLY_MAX_CONCURRENCY=2
AI_REPLY_RATE_LIMIT_PER_MINUTE=10
AI_REPLY_MAX_PROMPT_LENGTH=24000
# Optional browser user-agent override.
AI_REPLY_USER_AGENT=

# Internal faster-whisper service
TRANSCRIPTION_SERVICE_URL=http://127.0.0.1:8000
TRANSCRIPTION_SERVICE_API_KEY=
# Long recordings can require several minutes on CPU.
TRANSCRIPTION_TIMEOUT_MS=1800000

# Optional fast cloud transcription (https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
DEEPGRAM_API_KEY=
DEEPGRAM_TRANSCRIPTION_MODEL=nova-3
ASSEMBLYAI_API_KEY=
# Optional dedicated AES-256 key for credentials saved from the UI.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# If omitted, a separate key is derived from JWT_SECRET.
TRANSCRIPTION_CREDENTIAL_ENCRYPTION_KEY=
